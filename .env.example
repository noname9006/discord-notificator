DISCORD_TOKEN=

# --- Global Queue ---
GLOBAL_CHANNEL=your_global_channel_id
# Minutes between notifications after the first immediate send (default: 120 = 2 hours)
GLOBAL_INTERVAL_MINUTES=120
GLOBAL_MIN_MESSAGES=25
GLOBAL_COOLDOWN_MINUTES=15

# Comma-separated notification numbers to enable (e.g. 1,2,4).
# If unset or empty, ALL notifications in global.config.js are active.
GLOBAL_NOTIFICATIONS=

# --- Independent Notification 1 ---
INDEPENDENT_1_CHANNEL=your_independent_channel_id
INDEPENDENT_1_CRON_SCHEDULE=30 * * * *
INDEPENDENT_1_MIN_MESSAGES=5
INDEPENDENT_1_COOLDOWN_MINUTES=10

# Comma-separated independent notification numbers to enable (e.g. 1,3).
# If unset or empty, ALL entries in independent.config.js are active.
INDEPENDENT_NOTIFICATIONS=
