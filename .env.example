# Discord bot token (required)
DISCORD_TOKEN=your_discord_bot_token_here

# Channel ID to send notifications to (required)
NOTIFICATIONS_CHANNEL=your_channel_id_here

# Cron schedule for notifications (default: every hour)
# Examples:
#   "0 * * * *"    - every hour
#   "0 9 * * *"    - every day at 9:00 AM UTC
#   "*/30 * * * *" - every 30 minutes
NOTIFICATIONS_CRON_SCHEDULE=0 * * * *

# Minimum number of user messages in the channel since the last notification
# before the next notification is allowed (default: 10)
MIN_MESSAGES=10

# Minutes to wait before retrying when not enough messages have been posted (default: 15)
COOLDOWN_MINUTES=15
